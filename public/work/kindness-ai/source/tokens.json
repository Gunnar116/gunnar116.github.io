        "$type": "other",
        "$value": "linear-gradient(210.65deg, hsla(0,0%,98%,0.08) 32%, rgba(244,195,166,0.25)), linear-gradient(180deg, hsla(0,0%,98%,0.08), rgba(163,177,237,0.25)), linear-gradient(149.35deg, hsla(0,0%,98%,0.08) 32%, rgba(237,163,177,0.25))"
      }
    }
