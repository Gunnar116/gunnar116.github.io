      "delayedLoadingIndicator": {
        "$type": "transition",
        "$value": {
          "duration": 200,
          "delay": 500,
          "easing": "cubic-bezier(0.4,0,0.6,1)",
          "iterationCount": 1,
          "direction": "normal",
          "fillMode": "forwards"
        }
      },
      "loadingSkeletonPulse": {
        "$type": "transition",
        "$value": {
          "duration": 2000,
          "delay": 0,
          "easing": "cubic-bezier(0.4,0,0.6,1)",
          "iterationCount": "infinite",
          "direction": "normal"
        }
      }
    },
